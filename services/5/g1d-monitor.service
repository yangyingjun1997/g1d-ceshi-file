[Unit]
Description=G1D Status Monitor Web Dashboard
After=network.target multi-user.target
StartLimitBurst=3
StartLimitIntervalSec=60

[Service]
Type=simple
User=__G1D_USER__
WorkingDirectory=__G1D_HOME__
# 等30秒让 ROS2 DDS 完成远程节点发现后再启动
ExecStartPre=/bin/sleep 30
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && exec /usr/bin/python3 __G1D_HOME__/bin/status_monitor.py'
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
